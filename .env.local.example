# Copy this file to ".env.local" and fill in your Supabase project values.
# Project Settings -> API in the Supabase dashboard.

# Public Supabase URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose; row-level access is restricted by policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (SERVER ONLY — never expose to the browser).
# Used by the API routes to enforce one-submit-per-email and the score cap.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Maximum plausible score accepted by the submit API (anti-cheat sanity cap).
SCORE_MAX=500

# --- Admin panel (/admin) ---
# Fixed local login used to clear leaderboard data between trials.
# These have sensible defaults; override them here if you want.
ADMIN_EMAIL=admin@litmuschaos.io
ADMIN_PASSWORD=litmus@123Chaos
# Secret used to sign the admin session cookie (change to any random string).
ADMIN_SESSION_SECRET=change-me-to-a-random-string
